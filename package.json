{
  "name": "legal-citer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && node scripts/guard-production-secrets.mjs && next build",
    "start": "next start",
    "worker": "tsx -r tsconfig-paths/register src/worker/index.ts",
    "e2e:server": "concurrently -k -s first -n next,worker \"E2E_AUTH_BYPASS=1 npm run dev -- --hostname 127.0.0.1 --port ${PORT:-3100}\" \"npm run worker\"",
    "lint": "eslint .",
    "test": "npm run test:functional",
    "test:functional": "playwright test tests/e2e/upload-to-run.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:deployed": "playwright test --config playwright.deployed.config.ts",
    "test:ci": "npm run typecheck && npm run lint && npm run build && npm run test:e2e",
    "e2e:seed": "node scripts/seed-e2e.mjs",
    "e2e:cleanup": "node scripts/cleanup-e2e.mjs",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "node scripts/migrate-deploy.mjs",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^7.2.7",
    "@prisma/client": "^6.6.0",
    "@react-pdf/renderer": "^4.5.1",
    "bullmq": "^5.51.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.503.0",
    "mammoth": "^1.8.0",
    "nanoid": "^5.1.5",
    "next": "^15.3.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shadcn": "^4.5.0",
    "svix": "^1.92.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@clerk/testing": "^2.1.6",
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.15.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^4.1.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
