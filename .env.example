DATABASE_URL="postgresql://legalciter:legalciter@localhost:5432/legal_citer"
REDIS_URL="redis://localhost:6379"
MANIFEST_SIGNING_KEY="dev-signing-key-change-in-production"

UPLOAD_STORAGE_BACKEND="filesystem"
UPLOADS_DIR="./uploads"
# Railway Bucket / S3-compatible storage. Required when UPLOAD_STORAGE_BACKEND="s3".
S3_BUCKET_NAME=""
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Set to "1" only if the bucket credentials say path-style URLs are required.
S3_FORCE_PATH_STYLE="0"

COURTLISTENER_API_KEY=""
OPENROUTER_API_KEY=""

# GovInfo resolves U.S.C. statutory citations (e.g. "42 U.S.C. § 1983").
# Optional: when unset, the resolver falls back to the public DEMO_KEY
# (~50 requests/day). Set a real key from https://api.data.gov for higher
# rate limits.
GOVINFO_API_KEY=""

PACER_USERNAME=""
PACER_PASSWORD=""
PACER_OTP_SECRET=""
PACER_QA_MODE="true"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/upload"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/upload"
# NOTE: do NOT set *_FORCE_REDIRECT_URL here. FORCE overrides the original
# destination and would break deep links to /runs, /reports, etc. after sign-in.
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

DEPLOYED_BASE_URL=""
CLERK_TESTING_TOKEN=""
E2E_CLERK_USER_EMAIL=""
E2E_CLERK_ORG_ID=""
E2E_CLERK_ORG_NAME="Legal Citer E2E"
